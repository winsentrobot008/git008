{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start ClawAI Backend",
            "type": "shell",
            "command": "${workspaceFolder}/ClawAI/.venv/Scripts/python",
            "args": ["-m", "livebench.cli"],
            "options": {
                "cwd": "${workspaceFolder}/ClawAI"
            },
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "runOptions": {
                "runOn": "folderOpen"
            }
        },
        {
            "label": "Start ClawAI Frontend",
            "type": "shell",
            "command": "npm",
            "args": ["run", "dev"],
            "options": {
                "cwd": "${workspaceFolder}/ClawAI/frontend"
            },
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "runOptions": {
                "runOn": "folderOpen"
            }
        }
    ]
}