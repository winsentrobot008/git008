<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ClawWork 生产调度 - DeepSeek 多 Agent 协作</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;background:linear-gradient(135deg,#0f0c29,#302b63,#24243e);color:#e0e0e0;min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:2rem 1rem}
.container{max-width:1100px;width:100%}
header{text-align:center;margin-bottom:2.5rem}
header h1{font-size:2.2rem;font-weight:700;background:linear-gradient(90deg,#00d2ff,#3a7bd5,#00d2ff);background-size:200% auto;-webkit-background-clip:text;-webkit-text-fill-color:transparent;animation:shimmer 3s ease-in-out infinite}
@keyframes shimmer{0%,100%{background-position:0% center}50%{background-position:200% center}}
header p{color:#a0a0b8;margin-top:.5rem;font-size:.95rem}
.status-badge{display:inline-block;margin-top:.75rem;padding:.3rem 1rem;border-radius:20px;font-size:.8rem;font-weight:600}
.status-badge.online{background:rgba(0,200,83,.15);color:#00c853;border:1px solid rgba(0,200,83,.3)}
.status-badge.offline{background:rgba(255,82,82,.15);color:#ff5252;border:1px solid rgba(255,82,82,.3)}
.status-badge.checking{background:rgba(255,193,7,.15);color:#ffc107;border:1px solid rgba(255,193,7,.3)}
.card{background:rgba(255,255,255,.05);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:1.5rem;margin-bottom:1.5rem;transition:border-color .3s,box-shadow .3s}
.card:hover{border-color:rgba(0,210,255,.2);box-shadow:0 0 30px rgba(0,210,255,.05)}
.card h2{font-size:1.1rem;font-weight:600;margin-bottom:1rem;color:#b0b0d0;display:flex;align-items:center;gap:.5rem}
.card h2 .icon{font-size:1.3rem}
.input-group{display:flex;gap:.75rem;flex-wrap:wrap}
.input-group input,.input-group select{flex:1;min-width:200px;padding:.75rem 1rem;border-radius:10px;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.06);color:#e0e0e0;font-size:.95rem;outline:none;transition:border-color .3s}
.input-group input:focus,.input-group select:focus{border-color:#3a7bd5;box-shadow:0 0 0 3px rgba(58,123,213,.15)}
.input-group input::placeholder{color:#6a6a8a}
.input-group select option{background:#24243e;color:#e0e0e0}
.btn{padding:.75rem 1.5rem;border-radius:10px;border:none;font-size:.95rem;font-weight:600;cursor:pointer;transition:all .3s;display:inline-flex;align-items:center;gap:.5rem}
.btn-primary{background:linear-gradient(135deg,#3a7bd5,#00d2ff);color:#fff}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,210,255,.3)}
.btn-primary:disabled{opacity:.5;cursor:not-allowed;transform:none;box-shadow:none}
.btn-secondary{background:rgba(255,255,255,.08);color:#c0c0d8;border:1px solid rgba(255,255,255,.1)}
.btn-secondary:hover{background:rgba(255,255,255,.12)}
.btn-danger{background:rgba(255,82,82,.2);color:#ff5252;border:1px solid rgba(255,82,82,.3)}
.btn-danger:hover{background:rgba(255,82,82,.3)}
.live-stream{margin-top:1rem;padding:1rem;border-radius:10px;background:rgba(0,0,0,.3);min-height:200px;max-height:500px;overflow-y:auto;font-size:.85rem;line-height:1.6;font-family:'SF Mono','Fira Code','Consolas',monospace;display:none}
.live-stream.visible{display:block}
.live-stream .entry{padding:.3rem 0;border-bottom:1px solid rgba(255,255,255,.03);animation:fadeIn .3s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(-5px)}to{opacity:1;transform:translateY(0)}}
.live-stream .entry .time{color:#6a6a8a;font-size:.75rem;margin-right:.5rem}
.live-stream .entry .tag{display:inline-block;padding:.1rem .4rem;border-radius:4px;font-size:.7rem;font-weight:600;margin-right:.4rem;text-transform:uppercase}
.tag-thinking{background:rgba(255,193,7,.2);color:#ffc107}
.tag-code{background:rgba(0,210,255,.2);color:#00d2ff}
.tag-artifact{background:rgba(156,39,176,.2);color:#ce93d8}
.tag-submit{background:rgba(0,200,83,.2);color:#00c853}
.tag-complete{background:rgba(0,200,83,.3);color:#69f0ae}
.tag-error{background:rgba(255,82,82,.2);color:#ff5252}
.tag-info{background:rgba(33,150,243,.2);color:#64b5f6}
.tag-balance{background:rgba(255,152,0,.2);color:#ffb74d}
.live-stream .entry .msg{color:#c0c0d8}
.live-stream .entry .code-block{background:rgba(0,0,0,.3);border-left:2px solid #00d2ff;padding:.5rem;margin:.3rem 0;border-radius:4px;font-size:.8rem;white-space:pre-wrap;word-break:break-all;max-height:150px;overflow-y:auto;color:#a0d8ef}
.stream-controls{display:flex;gap:.5rem;margin-bottom:.75rem;align-items:center}
.stream-controls .ws-indicator{display:flex;align-items:center;gap:.4rem;font-size:.8rem;color:#7a7a9a}
.ws-dot{width:8px;height:8px;border-radius:50%;display:inline-block}
.ws-dot.connected{background:#00c853;box-shadow:0 0 6px #00c853}
.ws-dot.disconnected{background:#ff5252}
.ws-dot.connecting{background:#ffc107;animation:pulse 1s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.task-status-bar{display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:.75rem}
.task-status-item{display:flex;align-items:center;gap:.4rem;font-size:.85rem;color:#a0a0b8}
.task-status-item .num{font-weight:700;color:#00d2ff;font-size:1.1rem}
.agent-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem}
.agent-card{background:rgba(255,255,255,.04);border-radius:12px;padding:1rem;border:1px solid rgba(255,255,255,.06);transition:all .3s}
.agent-card:hover{background:rgba(255,255,255,.07);transform:translateY(-2px)}
.agent-card .name{font-weight:600;font-size:.95rem;margin-bottom:.4rem}
.agent-card .balance{font-size:1.3rem;font-weight:700;color:#00d2ff}
.agent-card .meta{font-size:.75rem;color:#7a7a9a;margin-top:.3rem}
.agent-card .status-dot{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:.3rem}
.status-dot.alive{background:#00c853}
.status-dot.bankrupt{background:#ff5252}
.status-dot.unknown{background:#7a7a9a}
.agent-card .busy-badge{display:inline-block;padding:.1rem .4rem;border-radius:4px;font-size:.7rem;background:rgba(255,193,7,.2);color:#ffc107;margin-left:.3rem}
.stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:.75rem;margin-bottom:1rem}
.stat-item{text-align:center;padding:.75rem;background:rgba(255,255,255,.03);border-radius:10px}
.stat-item .value{font-size:1.4rem;font-weight:700;color:#00d2ff}
.stat-item .label{font-size:.7rem;color:#7a7a9a;text-transform:uppercase;letter-spacing:.5px;margin-top:.2rem}
footer{margin-top:3rem;text-align:center;color:#5a5a7a;font-size:.8rem}
footer a{color:#3a7bd5;text-decoration:none}
footer a:hover{text-decoration:underline}
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(255,255,255,.1);border-radius:3px}
@media(max-width:600px){body{padding:1rem .75rem}header h1{font-size:1.6rem}.card{padding:1rem}.agent-grid{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="container">
<header>
<h1>ClawWork 生产调度</h1>
<p>DeepSeek 多 Agent 协作 · 实时流回传</p>
<span id="statusBadge" class="status-badge checking">检查连接中...</span>
</header>

<div class="card">
<h2>服务概览</h2>
<div class="stats-row">
<div class="stat-item"><div class="value" id="statAgents">-</div><div class="label">Agent 数量</div></div>
<div class="stat-item"><div class="value" id="statTasks">-</div><div class="label">总任务数</div></div>
<div class="stat-item"><div class="value" id="statBalance">-</div><div class="label">总余额 ($)</div></div>
<div class="stat-item"><div class="value" id="statIncome">-</div><div class="label">总收入 ($)</div></div>
</div>
</div>

<div class="card">
<h2>提交任务到调度器</h2>
<div class="input-group">
<input type="text" id="taskInput" placeholder="输入任务描述，例如：搞个3D投掷游戏" />
<select id="occupationSelect">
<option value="Software Engineer">软件工程师</option>
<option value="Data Scientist">数据科学家</option>
<option value="Writer">作家</option>
<option value="Designer">设计师</option>
<option value="Analyst">分析师</option>
</select>
<button class="btn btn-primary" id="submitBtn" onclick="submitTask()">提交</button>
</div>
<div class="task-status-bar" id="taskStatusBar" style="display:none">
<div class="task-status-item">运行中: <span class="num" id="runningCount">0</span></div>
<div class="task-status-item">已完成: <span class="num" id="completedCount">0</span></div>
<div class="task-status-item">失败: <span class="num" id="failedCount">0</span></div>
</div>
<div class="stream-controls">
<div class="ws-indicator"><span class="ws-dot disconnected" id="wsDot"></span><span id="wsStatus">未连接</span></div>
<button class="btn btn-secondary" id="connectWsBtn" onclick="toggleWebSocket()" style="padding:.4rem .75rem;font-size:.8rem">连接 WebSocket</button>
<button class="btn btn-secondary" onclick="clearStream()" style="padding:.4rem .75rem;font-size:.8rem">清空</button>
<button class="btn btn-danger" id="autoScrollBtn" onclick="toggleAutoScroll()" style="padding:.4rem .75rem;font-size:.8rem">自动滚动</button>
</div>
<div id="liveStream" class="live-stream">
<div class="entry"><span class="tag tag-info">INFO</span><span class="msg">连接到服务器后，Agent 的实时思考日志将显示在这里...</span></div>
</div>
</div>

<div class="card">
<h2>Agent 列表</h2>
<div id="agentList" class="agent-grid">
<div style="grid-column:1/-1;text-align:center;color:#7a7a9a;padding:2rem 0">加载中...</div>
</div>
</div>

<div class="card">
<h2>API 端点</h2>
<div style="font-size:.85rem;line-height:1.8;color:#a0a0b8">
<div><code style="background:rgba(255,255,255,.06);padding:.15rem .4rem;border-radius:4px">POST /api/tasks</code> 提交任务到调度器</div>
<div><code style="background:rgba(255,255,255,.06);padding:.15rem .4rem;border-radius:4px">GET /api/tasks/{id}</code> 查询任务状态</div>
<div><code style="background:rgba(255,255,255,.06);padding:.15rem .4rem;border-radius:4px">GET /api/tasks</code> 所有任务列表</div>
<div><code style="background:rgba(255,255,255,.06);padding:.15rem .4rem;border-radius:4px">GET /api/scheduler/agents</code> 调度器 Agent 状态</div>
<div><code style="background:rgba(255,255,255,.06);padding:.15rem .4rem;border-radius:4px">WS /ws</code> WebSocket 实时流</div>
</div>
</div>

<footer>
ClawWork 生产调度
</footer>
</div>

<script>
var API_BASE = window.location.origin;
var ls = localStorage.getItem('clawwork_api_base');
if (ls) API_BASE = ls;

var ws = null, wsConnected = false, autoScroll = true;
var runningTasks = 0, completedTasks = 0, failedTasks = 0;

function apiGet(path) {
  return fetch(API_BASE + path, {headers:{Accept:'application/json'},signal:AbortSignal.timeout(15000)}).then(function(r){if(!r.ok)throw new Error('HTTP '+r.status);return r.json()});
}
function apiPost(path, body) {
  return fetch(API_BASE + path, {method:'POST',headers:{'Content-Type':'application/json',Accept:'application/json'},body:JSON.stringify(body),signal:AbortSignal.timeout(10000)}).then(function(r){if(!r.ok)throw new Error('HTTP '+r.status);return r.json()});
}

function checkConnection() {
  var b = document.getElementById('statusBadge');
  b.className = 'status-badge checking'; b.textContent = '检查连接中...';
  apiGet('/api/health').then(function(){
    b.className = 'status-badge online'; b.textContent = '已连接';
  }).catch(function(e){
    b.className = 'status-badge offline'; b.textContent = '无法连接: '+e.message;
  });
}

function connectWs() {
  var url = API_BASE.replace(/^http/,'ws')+'/ws';
  var dot = document.getElementById('wsDot'), st = document.getElementById('wsStatus'), btn = document.getElementById('connectWsBtn');
  dot.className = 'ws-dot connecting'; st.textContent = '连接中...'; btn.textContent = '连接中...'; btn.disabled = true;
  ws = new WebSocket(url);
  ws.onopen = function(){ wsConnected=true; dot.className='ws-dot connected'; st.textContent='已连接'; btn.textContent='断开'; btn.disabled=false; addEntry('info','WebSocket 已连接'); };
  ws.onmessage = function(e){ try{ handleMsg(JSON.parse(e.data)); }catch(ex){ addEntry('info',e.data); } };
  ws.onclose = function(){ wsConnected=false; dot.className='ws-dot disconnected'; st.textContent='未连接'; btn.textContent='连接 WebSocket'; btn.disabled=false; addEntry('info','WebSocket 已断开'); };
  ws.onerror = function(){ addEntry('error','WebSocket 连接错误'); ws.close(); };
}
function disconnectWs(){ if(ws){ ws.close(); ws=null; } }
function toggleWebSocket(){ if(wsConnected) disconnectWs(); else connectWs(); }

function handleMsg(msg){
  var t = msg.type||'unknown';
  switch(t){
    case 'connected': case 'heartbeat': case 'pong': break;
    case 'agent_initializing': addEntry('info','Agent ['+msg.agent+'] 正在初始化 ('+msg.model+')...'); break;
    case 'agent_initialized': addEntry('info','Agent ['+msg.agent+'] 初始化完成'); break;
    case 'task_queued': addEntry('info','任务 ['+msg.task_id.slice(-8)+'] 已排队 -> Agent ['+msg.agent+']'); updateCounts(); break;
    case 'task_started': runningTasks++; updateCounts(); addEntry('info','任务 ['+msg.task_id.slice(-8)+'] 开始执行'); break;
    case 'task_assigned': addEntry('info','任务已分配: '+(msg.prompt||'').slice(0,80)); break;
    case 'agent_thinking': var th=msg.thought||msg.message||''; if(th) addEntry('thinking',th.slice(0,200)); break;
    case 'tool_calls': addEntry('info','调用工具 ('+msg.count+'): '+(msg.tools||[]).join(', ')); break;
    case 'code_generated': addEntry('code','生成代码 ('+(msg.language||'python')+'):',(msg.code||'').slice(0,300)); break;
    case 'artifact_created': addEntry('artifact','创建文件: '+(msg.file_path||'')); break;
    case 'work_submitted': addEntry('submit','工作已提交! 支付: $'+(msg.payment||0).toFixed(2)+' 评分: '+(msg.evaluation_score||0).toFixed(2)); break;
    case 'task_completed': runningTasks=Math.max(0,runningTasks-1); completedTasks++; updateCounts(); addEntry('complete','任务完成! 支付: $'+(msg.payment||0).toFixed(2)); loadData(); break;
    case 'task_incomplete': runningTasks=Math.max(0,runningTasks-1); failedTasks++; updateCounts(); addEntry('error','任务未完成: '+(msg.reason||'未知')); break;
    case 'task_error': runningTasks=Math.max(0,runningTasks-1); failedTasks++; updateCounts(); addEntry('error','任务错误: '+(msg.error||'').slice(0,200)); break;
    case 'task_finished': addEntry('complete','任务结束 | 状态: '+msg.status+' | 支付: $'+(msg.payment||0).toFixed(2)); loadData(); break;
    case 'balance_update': if(msg.data&&msg.data.balance!==undefined) addEntry('balance','Agent ['+msg.signature+'] 余额: $'+msg.data.balance.toFixed(2)); break;
    case 'activity_update': if(msg.data&&msg.data.activity) addEntry('info','Agent ['+msg.signature+'] 活动: '+msg.data.activity); break;
    default: addEntry('info',t+': '+JSON.stringify(msg).slice(0,200));
  }
}

function addEntry(tag, msg, code){
  var stream = document.getElementById('liveStream');
  stream.classList.add('visible');
  var entry = document.createElement('div');
  entry.className = 'entry';
  var time = new Date().toLocaleTimeString();
  var tagMap = {thinking:'tag-thinking',code:'tag-code',artifact:'tag-artifact',submit:'tag-submit',complete:'tag-complete',error:'tag-error',info:'tag-info',balance:'tag-balance'};
  var tc = tagMap[tag]||'tag-info';
  var h = '<span class="time">'+time+'</span><span class="tag '+tc+'">'+tag.toUpperCase()+'</span><span class="msg">'+esc(msg)+'</span>';
  if(code) h += '<div class="code-block">'+esc(code)+'</div>';
  entry.innerHTML = h;
  stream.appendChild(entry);
  while(stream.children.length>200) stream.removeChild(stream.firstChild);
  if(autoScroll) stream.scrollTop = stream.scrollHeight;
}
function esc(t){var d=document.createElement('div');d.textContent=t;return d.innerHTML;}
function clearStream(){var s=document.getElementById('liveStream');s.innerHTML='';s.classList.remove('visible');}
function toggleAutoScroll(){autoScroll=!autoScroll;document.getElementById('autoScrollBtn').textContent=autoScroll?'自动滚动':'手动滚动';if(autoScroll)document.getElementById('liveStream').scrollTop=document.getElementById('liveStream').scrollHeight;}
function updateCounts(){document.getElementById('runningCount').textContent=runningTasks;document.getElementById('completedCount').textContent=completedTasks;document.getElementById('failedCount').textContent=failedTasks;document.getElementById('taskStatusBar').style.display='flex';}

function loadData(){
  apiGet('/api/agents').then(function(d){
    var agents = d.agents||[];
    var c = document.getElementById('agentList');
    if(!agents.length){c.innerHTML='<div style="grid-column:1/-1;text-align:center;color:#7a7a9a;padding:2rem 0">暂无 Agent 数据</div>';return;}
    c.innerHTML = agents.map(function(a){
      var st = (a.survival_status||'unknown').toLowerCase();
      var dc = st==='alive'?'alive':st==='bankrupt'?'bankrupt':'unknown';
      var busy = a.current_activity&&a.current_activity!=='rest';
      return '<div class="agent-card"><div class="name">'+a.signature+(busy?'<span class="busy-badge">忙碌</span>':'')+'</div><div class="balance">$'+(a.balance||0).toFixed(2)+'</div><div class="meta"><span class="status-dot '+dc+'"></span>'+(a.survival_status||'Unknown')+(a.current_date?' '+a.current_date:'')+'</div><div class="meta">成本: $'+(a.total_token_cost||0).toFixed(2)+'</div></div>';
    }).join('');
    document.getElementById('statAgents').textContent = agents.length;
    document.getElementById('statTasks').textContent = agents.reduce(function(s,a){return s+(a.num_tasks||0);},0);
    document.getElementById('statBalance').textContent = agents.reduce(function(s,a){return s+(a.balance||0);},0).toFixed(2);
    document.getElementById('statIncome').textContent = agents.reduce(function(s,a){return s+(a.total_token_cost||0);},0).toFixed(2);
  }).catch(function(e){
    document.getElementById('agentList').innerHTML = '<div style="grid-column:1/-1;text-align:center;color:#ff8a80;padding:2rem 0">加载失败: '+e.message+'</div>';
  });
}

function submitTask(){
  var input = document.getElementById('taskInput');
  var task = input.value.trim();
  var occ = document.getElementById('occupationSelect').value;
  var btn = document.getElementById('submitBtn');
  if(!task){ addEntry('error','请输入任务描述'); return; }
  btn.disabled = true;
  addEntry('info','正在提交任务: '+task.slice(0,80)+'...');
  apiPost('/api/tasks',{prompt:task,occupation:occ}).then(function(res){
    addEntry('complete','任务已提交! ID: '+res.task_id.slice(-8)+' Agent: '+res.agent+' 状态: '+res.status);
    input.value = '';
  }).catch(function(e){
    addEntry('error','提交失败: '+e.message);
  }).finally(function(){ btn.disabled = false; });
}

checkConnection();
loadData();
</script>
</body>
</html>
