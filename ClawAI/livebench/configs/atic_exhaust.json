{
  "livebench": {
    "date_range": {
      "init_date": "2025-01-20",
      "end_date": "2026-01-20"
    },
    "economic": {
      "initial_balance": 10.0,
      "task_values_path": "./scripts/task_value_estimates/task_values.jsonl",
      "token_pricing": {
        "input_per_1m": 0.50,
        "output_per_1m": 1.50
      }
    },
    "agents": [
      {
        "signature": "ATIC + Qwen3.5-Plus",
        "basemodel": "atic-brain",
        "enabled": true,
        "tasks_per_day": 1,
        "supports_multimodal": false
      }
    ],
    "agent_params": {
      "max_steps": 15,
      "max_retries": 3,
      "base_delay": 0.5,
      "api_timeout": 360.0
    },
    "evaluation": {
      "use_llm_evaluation": true,
      "meta_prompts_dir": "./eval/meta_prompts"
    },
    "data_path": "./livebench/data/agent_data",
    "gdpval_path": "./gdpval"
  }
}
